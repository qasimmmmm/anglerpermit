# Optional — the app works with zero env vars (dev-mode console fallbacks).

# ─── Email (Resend) — see EMAIL_SETUP.md for the full runbook ─────────────
# Secret API key from https://resend.com/api-keys (starts with "re_").
# When unset, every email becomes a server-console log instead (dev mode).
RESEND_API_KEY=
# Where admin notifications (new orders, contact messages, license-delivery
# copies) go. Comma-separate for multiple recipients.
ADMIN_EMAIL=
# Sender identities — the domain must be verified in Resend first.
# Defaults (when unset) are shown:
EMAIL_FROM="AnglerPermit <orders@anglerpermit.com>"
EMAIL_FROM_SUPPORT="AnglerPermit Support <support@anglerpermit.com>"
EMAIL_FROM_LICENSES="AnglerPermit <licenses@anglerpermit.com>"
# Reply-to address on customer-facing emails.
SUPPORT_REPLY_TO=support@anglerpermit.com
# OPT-IN: include the full (unmasked) SSN in admin new-order emails for
# fulfillment. Default keeps SSNs masked ***-**-####. Email is not encrypted
# at rest — enable only if fulfillment truly requires it, and delete those
# emails once the license is purchased.
# ADMIN_EMAIL_INCLUDE_FULL_SSN=true
# Secret protecting the unlisted /admin/deliver page (license delivery).
# Generate one with:  openssl rand -base64 24
ADMIN_PANEL_SECRET=

NEXT_PUBLIC_SITE_URL=https://anglerpermit.com

# --- Database (Postgres) --------------------------------------------------
# Neon / Supabase / any Postgres. Use a POOLED connection string in production
# (serverless). When unset, the site still works: applications fall back to
# console logging and DB-backed features (retry links, dunning) are disabled.
# Apply migrations with:  npm run db:migrate
DATABASE_URL=

# --- NMI payment gateway -------------------------------------------------
# Card data is tokenized CLIENT-SIDE (Collect.js); our server only ever
# sees a single-use payment_token. NEVER hardcode real keys in the repo,
# and NEVER add raw card fields to any API route (PCI SAQ-A depends on it).
#
# Public tokenization key — safe for the browser; used by the client script.
NEXT_PUBLIC_NMI_TOKENIZATION_KEY=
# SERVER ONLY — private security key for the Direct Post API (transact.php).
# (NMI_SECURITY_KEY is accepted as an alias.) When unset, the gateway runs
# in dev mode and SIMULATES successful charges.
NMI_PRIVATE_SECURITY_KEY=
# Optional gateway endpoint override (defaults to NMI's standard endpoint).
# NMI_API_URL=https://secure.networkmerchants.com/api/transact.php
# Card-statement descriptor shown on the customer's receipt.
NMI_DESCRIPTOR="ANGLER PERMIT"
# OPT-IN: store cards in NMI's Customer Vault on checkout so payment-retry
# links can offer "use card on file". Requires consent copy at checkout —
# leave off until that copy ships.
# NMI_ENABLE_CUSTOMER_VAULT=true
